{
    "manifest_version": 3,
    "name": "OrderHistory++",
    "version": "0.2",
    "description": "Enhances the Order History page with live commission tracking, actual customer counts, and item filtering.",
    "content_scripts": [
      {
        "matches": ["*://orderhistory.microcenter.com/*"],
        "js": ["content.js"],
        "css": ["styles.css"]
      }
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "orderhistoryplus@microcenter.local",
        "strict_min_version": "109.0"
      }
    }
  }